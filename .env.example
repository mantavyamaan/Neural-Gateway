# Neural Gateway Router — example environment configuration.
# Copy to .env and adjust. Currently the app reads no env vars at import
# time (the registry is built in-process), but this file is a placeholder
# for real deployments — e.g. wiring an external registry/telemetry source,
# or an LLM-backed semantic parser.

# Uvicorn
HOST=0.0.0.0
PORT=8000

# Optional: point the artifact inspector's ffprobe check at a custom binary
# FFPROBE_PATH=/usr/bin/ffprobe

# Optional: if you wire a real structured-output LLM parser (see
# app/core/semantic_parser.py -> parse_with_llm_interface), its API key
# would go here, e.g.:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Restrict routing to models from specific providers. Comma-separated list.
# Applied as the default `allowed_providers` for every /route request when the
# caller doesn't set its own. Callers can still override per-request.
# Examples:
#   NEURAL_GATEWAY_ALLOWED_PROVIDERS=OpenAI
#   NEURAL_GATEWAY_ALLOWED_PROVIDERS=Anthropic
#   NEURAL_GATEWAY_ALLOWED_PROVIDERS=OpenAI,Anthropic
# Leave unset to route across all providers (default multi-provider behavior).
# NEURAL_GATEWAY_ALLOWED_PROVIDERS=

# Optional: tune the confidence-based escalation ladder. The defaults assume
# a multi-provider registry — with a narrow single-provider allowlist, drop
# NEURAL_GATEWAY_ABSTAIN_THRESHOLD to ~0.30 so the router doesn't refuse borderline
# cases where the top model won 35-40% of simulations.
# NEURAL_GATEWAY_ABSTAIN_THRESHOLD=0.30       # below this -> abstain (default 0.40)
# NEURAL_GATEWAY_ESCALATE_THRESHOLD=0.45      # below this -> escalate flag (default 0.55)
# NEURAL_GATEWAY_HIGH_THRESHOLD=0.70          # above this -> auto on high-risk (default 0.75)

# Embedding model for the domain classifier (fastembed / ONNX runtime).
# Downloaded once to ~/.cache/fastembed on first startup (~30MB for BGE-small).
# Other good options: sentence-transformers/all-MiniLM-L6-v2 (smaller, ~22MB),
# nomic-ai/nomic-embed-text-v1.5 (768-dim, higher quality, larger).
# NEURAL_GATEWAY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM tiebreaker: called only when the embedding classifier's cosine
# similarity is below 0.55 AND the prompt is text-only AND no regulated-
# advice keyword fired. Requires OPENAI_API_KEY. Set to empty to disable.
NEURAL_GATEWAY_LLM_PARSER_MODEL=gpt-4o-mini

# Security and production safety. Synthetic/name-derived registry records are
# rejected by default; set false only for local demos and tests.
NEURAL_GATEWAY_REQUIRE_MEASURED_EVIDENCE=true
# Do not expose raw server filesystem paths through the public API.
NEURAL_GATEWAY_ALLOW_SERVER_FILE_PATHS=false
# Required to enable POST /models, DELETE /models/{name}, and POST /outcome.
# NEURAL_GATEWAY_ADMIN_API_KEY=replace-with-a-long-random-secret
# Comma-separated browser origins. Do not use * in production.
NEURAL_GATEWAY_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ==============================================================================
# Cloud LLM Parser Configuration (Optional Alternative to Local Ollama)
# ==============================================================================
# By default, Neural Gateway uses a local Ollama llama3.1 model to parse prompts for routing.
# If you want lightning-fast parsing (<500ms) and do not want to run Ollama locally, 
# you can provide a Cloud API key below. To switch back to Ollama, simply comment 
# out the NEURAL_GATEWAY_PARSER_API_KEY.
#
# NEURAL_GATEWAY_PARSER_API_KEY="your-gemini-api-key-here"
# NEURAL_GATEWAY_PARSER_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# NEURAL_GATEWAY_PARSER_MODEL="gemini-2.0-flash"
